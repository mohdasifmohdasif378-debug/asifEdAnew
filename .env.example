# REQUIRED: Generate a random 32+ character secret key
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# OPTIONAL: Anthropic Claude API key (for production AI features)
# Leave empty to use local code-based assistant
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Database URL (SQLite for dev, upgrade to PostgreSQL for production)
DATABASE_URL=sqlite:///./data/asifeda.db

# CORS: Comma-separated list of allowed frontend origins
# For development:
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# For production:
# FRONTEND_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Optional: Rate limiting (requests per minute, 0 = disabled)
RATE_LIMIT_PER_MINUTE=60